NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PORT=3001

# Vercel 部署：在 Vercel 後台設定 NOTION_API_KEY 與 NOTION_DATABASE_ID 即可。
# 前後端同網域（/api），不需要設定 VITE_API_URL 或 CORS_ORIGIN。

# 僅當後端與前端不同網域時才需要（本機開發留空）：
# VITE_API_URL=https://your-app.example.com/api
# CORS_ORIGIN=https://your-frontend.example.com
